generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id          String   @id @default(uuid())
  title       String
  content     String   @db.Text
  createdAt   DateTime @default(now())
  authorName  String
  authorEmail String
  authorPhoto String?
  tags        Tag[]    
}

model Tag {
  id    String @id @default(uuid())
  name  String @unique
  posts Post[] 
}
model CommunityMember {
  id          String   @id @default(uuid())
  name        String
  email       String
  contact     String
  status      String   // Student or Working
  about       String   @db.Text
  whyJoin     String   @db.Text
  createdAt   DateTime @default(now())
}